{
  "name": "rimr",
  "private": true,
  "version": "0.2.1",
  "description": "A RimWorld mod manager.",
  "author": "Rhynia",
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "vite",
    "bindings": "cargo run -p xtask -- export-bindings",
    "bindings:check": "cargo run -p xtask -- export-bindings --check",
    "build": "pnpm typecheck && vite build",
    "build:bin": "tauri build --no-bundle",
    "typecheck": "tsc --noEmit -p tsconfig.json --pretty false && tsc --noEmit -p tsconfig.node.json --pretty false",
    "lint": "oxlint src vite.config.ts vitest.config.ts --deny-warnings",
    "fmt": "oxfmt --write src",
    "fmt:check": "oxfmt --check src",
    "test": "vitest run",
    "bump": "tsx scripts/bump-version.ts",
    "check": "pnpm bindings:check && pnpm fmt:check && pnpm lint && pnpm typecheck && pnpm build && pnpm test && cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings && cargo test --workspace"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-virtual": "^3.14.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-log": "^2",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.1",
    "lucide-react": "^1.21.0",
    "neverthrow": "^8.2.0",
    "radix-ui": "^1.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.0.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^4.6.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "semver": "^7.8.5",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
