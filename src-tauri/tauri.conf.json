{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RimR",
  "mainBinaryName": "RimR",
  "version": "0.1.4",
  "identifier": "org.rhnu.rimr",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RimR",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "category": "Utility",
    "copyright": "Copyright (C) 2026 Rhynia. Licensed under the GNU General Public License v3.",
    "publisher": "Rhynia",
    "license": "GPL-3.0",
    "licenseFile": "../LICENSE",
    "shortDescription": "A RimWorld mod manager.",
    "longDescription": "RimR is a desktop mod manager for RimWorld.",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
